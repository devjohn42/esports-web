# Normalizar tudo como LF
* text=auto eol=lf

# Scripts Windows
*.bat text eol=crlf
*.cmd text eol=crlf

# Scripts Unix
*.sh text eol=lf

# Arquivos comuns
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Markdown
*.md text eol=lf

# Binários (não mexer)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
